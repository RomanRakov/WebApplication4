@{
    ViewData["Title"] = "Главная";
}


<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
              
                <div class="rating-badge mb-4">
                    <div class="stars">★★★★★</div>
                    <div class="rating-text">Все отзывы на 5 звезд</div>
                </div>

               
                <h1 class="hero-title mb-3">
                    Выкупим вашу квартиру в Москве и МО с любыми обременениями и в любом состоянии за 1 день
                </h1>

               
                <p class="hero-subtitle mb-4">
                    Выплатим на руки до 95% рыночной стоимости безопасным и удобным для Вас способом
                </p>

            
                <a href="#test" class="btn btn-primary btn-lg rounded-pill px-5">
                    Узнать цену выкупа
                </a>

               
                <p class="hero-note">Предложим цену выше, чем другие</p>
            </div>

            <div class="col-lg-5">
              
                <div class="info-cards">
                    <div class="info-card">
                        <div class="info-card-icon">↑</div>
                        <div class="info-card-percent">95%</div>
                        <div class="info-card-text">Выплатим до 95% стоимости и закроем все обременения</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

