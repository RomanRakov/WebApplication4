                       asp-route-id="2">

                    Подробнее

                </a>

            </div>

        </div>

    </div>



    <div class="col-md-4">

        <div class="card">

            <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2"
                 class="card-img-top">

            <div class="card-body">

                <h5>1-комнатная</h5>

                <p>Москва</p>

                <p>3 000 000 ₽</p>

                <a class="btn btn-primary"
                       asp-controller="Flat"
                       asp-action="Details"
