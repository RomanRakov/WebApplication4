<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Дом недвижимости</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>

<body>


    <!-- MENU -->

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-house-heart me-2" viewBox="0 0 16 16">
                <path d="M8 3.293l6 6V13a1 1 0 0 1-1 1H7v-4H3.5a.5.5 0 0 1-.5-.5.5.5 0 0 1 .5-.5h4V3.293l-6 6V13a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V7.414l7-7a1 1 0 0 1 1.414 0l7 7V9a.5.5 0 0 1-1 0V7.414l-6-6z"/>
                <path d="M9 13a1 1 0 1 0 2 0 1 1 0 0 0-2 0z"/>
            </svg>
            <div>
                <div class="fw-bold">МОСКОВСКИЙ ДОМ</div>
                <div class="small">НЕДВИЖИМОСТИ</div>
            </div>
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link active rounded-pill px-4" asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                </li>
                    <li class="nav-item">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a class="nav-link rounded-pill px-4" asp-controller="Announcements" asp-action="Index">Объявления</a>
                        }
                        else
                        {
                            <!-- Если НЕ залогинен - показывает кнопку Войти -->
                            <a class="nav-link rounded-pill px-4 text-secondary" href="/Account/Login">Войти</a>
                        }
                    </li>
                

                <li class="nav-item">
                        <a class="nav-link rounded-pill px-4" href="/Home/Index#questions">Вопрос-ответ</a>
                </li>
               
                <li class="nav-item">
                        <a class="nav-link rounded-pill px-4" href="/Home/Index#reviews">Отзывы</a>
                </li>
            </ul>
        </div>
        
        <div class="d-flex align-items-center">
            <a href="tel:+79990007896" class="btn btn-outline-primary rounded-pill me-2">+7 (999) 000-78-96</a>
          
        </div>
    </div>
</nav>



    <!-- BODY -->

    <div class="container mt-4">

        @RenderBody()

    </div>



    <!-- FOOTER -->

    <footer class="bg-dark text-white text-center p-3 mt-5">

        Дом недвижимости © 2026

    </footer>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>