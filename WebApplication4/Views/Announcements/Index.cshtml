@model IEnumerable<WebApplication4.Models.Flat>

@{
    ViewData["Title"] = "Объявления";
    var isAdmin = (bool?)ViewData["IsAdmin"];
}

<div class="container py-5">
    <h1 class="mb-4">@TempData["Success"]</h1>

    <!-- Сообщения для разных ролей -->
    @if (isAdmin == true)
    {
        <div class="alert alert-info">
            <strong>Режим администратора:</strong><br>
            Здесь вы можете модерировать предложения пользователей и публиковать объявления.
            <a href="@Url.Action("Moderation", "Announcements")" class="btn btn-sm btn-light mt-2">Перейти к модерации</a>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <strong>Вы — пользователь:</strong><br>
            Просматривайте доступные объявления или добавьте своё предложение.
        </div>

        <a asp-action="Create" class="btn btn-primary mb-4">
            ➕ Предложить свою квартиру
        </a>
    }

    <!-- Список объявлений -->
    <div class="row">
        <div class="col-12">
            <p class="text-muted small">Здесь будет отображаться список одобренных объявлений...</p>
        </div>
    </div>

    <!-- Кнопки действий для разных ролей -->
    <div class="mt-4 text-end">
        @if (isAdmin == true)
        {
            <button class="btn btn-danger me-2">🚫 Отклонить выбранное</button>
        }
        <a asp-action="Create" class="btn btn-outline-secondary">➕ Создать предложение</a>
    </div>
</div>