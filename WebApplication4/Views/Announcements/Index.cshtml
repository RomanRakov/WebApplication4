@model IEnumerable<WebApplication4.Models.Flat>
@{
    ViewData["Title"] = "Объявления";
    var isAdmin = (bool?)ViewData["IsAdmin"] ?? false;
}

<div class="container py-5">
    <h1 class="mb-4">@ViewData["Title"]</h1>

    @if (isAdmin)
    {
        <div class="alert alert-info">
            <strong>Режим администратора</strong><br />
            <a href="@Url.Action("Moderation", "Announcements")" class="btn btn-sm btn-light mt-2">Перейти к модерации</a>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <strong>Вы — пользователь</strong><br />
            Просматривайте доступные объявления или добавьте своё предложение.
        </div>
        <a asp-action="Create" class="btn btn-primary mb-4">➕ Предложить недвижимость</a>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var flat in Model)
            {
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@flat.ObjectType.GetDisplayName(), @flat.Area м²</h5>
                            <h6 class="card-subtitle mb-2 text-primary">@(flat.Price?.ToString("C") ?? "Цена не указана")</h6>
                            <p class="card-text">
                                Комнат: @flat.Rooms.GetDisplayName()<br />
                                Адрес: @flat.Address<br />
                                Состояние: @flat.Condition.GetDisplayName()<br />
                                Обременения: @flat.Encumbrance.GetDisplayName()<br />
                                Телефон: @flat.PhoneNumber
                            </p>
                            <p class="card-text">@flat.Description</p>
                        </div>
                        <div class="card-footer text-muted">
                            Опубликовано: @flat.PublishedAt.ToString("dd.MM.yyyy")
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">Пока нет опубликованных объявлений.</p>
    }
</div>