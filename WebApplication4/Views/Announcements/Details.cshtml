@model WebApplication4.Models.Suggestion
@{
    ViewData["Title"] = "Подробная информация о предложении";
}

<div class="container py-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white">
            <h3>@Model.ObjectType.GetDisplayName() – @Model.Area м²</h3>
        </div>
        <div class="card-body">
            <p><strong>💰 Цена:</strong> @(Model.Price?.ToString("C") ?? "не указана")</p>
            <p><strong>📐 Площадь:</strong> @Model.Area м²</p>
            <p><strong>🚪 Комнат:</strong> @Model.Rooms.GetDisplayName()</p>
            <p><strong>🏠 Состояние:</strong> @Model.Condition.GetDisplayName()</p>
            <p><strong>⚠️ Обременения:</strong> @Model.Encumbrance.GetDisplayName()</p>
            <p><strong>📍 Адрес:</strong> @Model.Address</p>
            <p><strong>📞 Телефон:</strong> @Model.PhoneNumber</p>
            <hr />
            <p class="fst-italic">@Model.Description</p>

            @if (User.IsInRole("Admin"))
            {
                <div class="mt-4">
                    <form asp-action="Approve" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success">✅ Одобрить</button>
                    </form>
                    <form asp-action="Reject" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger">❌ Отклонить</button>
                    </form>
                </div>
            }

            <a asp-action="Index" class="btn btn-outline-secondary mt-3">← Назад</a>
        </div>
    </div>
</div>